{
  "name": "hookepak",
  "version": "0.1.0",
  "type": "module",
  "description": "World-class packaging CAD with AI engineering intelligence",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:web": "vite",
    "dev:api": "cd backend && py -3 -m uvicorn main:app --reload --host 127.0.0.1 --port 8000",
    "dev:stack": "concurrently \"npm run dev:api\" \"vite\"",
    "dev:full": "concurrently \"npm run dev:api\" \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "dist": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.hookepak.app",
    "productName": "HookePak",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "assets/**"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis"
      ]
    }
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "autoprefixer": "^10.5.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "framer-motion": "^12.38.0",
    "postcss": "^8.5.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.2",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "vite": "^8.0.8",
    "wait-on": "^9.0.5"
  }
}
